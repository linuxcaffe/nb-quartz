{
  "name": "shop",
  "description": "Vintage shop — item listings, categories, image gallery",
  "version": "1.0.0",
  "components": [
    "ShopHome", "ShopNav", "ItemGrid", "ItemGallery", "ItemMeta",
    "ItemCategory", "CategoryContent", "FeaturedItem", "TagFeed", "imageUtils"
  ],
  "plugins": {
    "filters":      ["shopStatus"],
    "transformers": ["categoryToTag"],
    "emitters":     ["categoryPage"]
  },
  "layout": {
    "beforeBody": ["ShopNav", "ShopHome (conditional)", "ItemGallery", "ItemMeta", "ItemCategory", "TagFeed"],
    "left":       [],
    "right":      []
  }
}
